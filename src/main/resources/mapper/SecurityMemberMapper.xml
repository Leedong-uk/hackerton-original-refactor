<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="backend.kb_hack.global.security.mapper.SecurityMemberMapper">

    <resultMap id="authMap" type="backend.kb_hack.global.security.entity.MemberAuthVO">
        <result property="auth" column="status"/>
    </resultMap>

    <resultMap id="BusinessMap" type="backend.kb_hack.domain.business.dto.BusinessDTO">
        <id     property="businessId"       column="business_id"/>
        <result property="businessCodeId"   column="business_code"/>
        <result property="name"             column="name"/>
        <result property="businessAddr"     column="business_addr"/>
        <result property="businessAddrDetail" column="business_addr_detail"/>
        <result property="businessNumber"   column="business_number"/>
        <result property="businessOpenDate" column="business_open_date"/>
    </resultMap>

    <resultMap id="MemberMap" type="backend.kb_hack.global.security.entity.MemberVO">
        <id     property="memberId"     column="member_id"/>
        <result property="storageKey"   column="storage_key"/>
        <result property="email"        column="email"/>
        <result property="password"     column="password"/>
        <result property="name"         column="name"/>
        <result property="createdDate"  column="created_date"/>
        <result property="helpCount"    column="help_count"/>
        <result property="badge"        column="badge"/>
        <association property="businessDTO" resultMap="BusinessMap"/>
        <collection  property="authMap"     resultMap="authMap"/>
    </resultMap>

    <select id="getMemberByMemberEmail" parameterType="string" resultMap="MemberMap">
        SELECT
            m.member_id,
            i.storage_key,
            m.email,
            m.password,
            m.name,
            m.created_date,
            m.help_count,
            m.badge,
            a.status,
            b.business_id,
            b.business_code,
            b.name,
            b.business_addr,
            b.business_addr_detail,
            b.business_number,
            b.business_open_date
        FROM member m
                 LEFT JOIN auth          a ON a.member_id = m.member_id
                 LEFT JOIN business      b ON b.member_id = m.member_id
                 LEFT JOIN profile_image i ON i.member_id = m.member_id
        WHERE m.email = #{memberEmail}
    </select>


    <select id="getMinorNmByBusinessId" resultType="java.lang.String">
        SELECT bc.minor_name
        FROM business_code bc
                 JOIN business b ON bc.business_code_id = b.business_code
        WHERE b.business_id = #{businessId}
    </select>
</mapper>