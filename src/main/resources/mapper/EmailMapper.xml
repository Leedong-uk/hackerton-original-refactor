<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="backend.kb_hack.domain.email.mapper.EmailMapper">

    <select id="findMemberIDByEmail" resultType="java.lang.Long">
        SELECT member_id
        FROM member
        WHERE email = #{email}
    </select>

</mapper>