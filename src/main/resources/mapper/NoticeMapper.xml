<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="backend.kb_hack.domain.notice.mapper.NoticeMapper">

    <select id="getAllNotice" resultType="backend.kb_hack.domain.notice.dto.NoticeDTO">
        SELECT title , notice_id
        FROM notice
    </select>

    <select id="getNoticeDetail" resultType="backend.kb_hack.domain.notice.dto.NoticeDetailDTO">
        SELECT *
        FROM notice
        WHERE notice_id = #{noticeId}
    </select>
</mapper>