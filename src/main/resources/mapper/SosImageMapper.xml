<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="backend.kb_hack.domain.sos.mapper.SosImageMapper">
    <insert id="insert" parameterType="backend.kb_hack.domain.sos.entity.SosImage"
            useGeneratedKeys="true" keyProperty="sosImageId" keyColumn="sos_image_id">
        INSERT INTO sos_image (sos_id, storage_key, sort_order)
        VALUES (#{sosId}, #{storageKey}, #{sortOrder})
    </insert>

    <delete id="deleteBySosId">
        DELETE FROM sos_image
        WHERE sos_id = #{sosId}
    </delete>

    <select id="findBySosId" resultType="backend.kb_hack.domain.sos.entity.SosImage">
        SELECT
            sos_image_id,
            sos_id,
            storage_key,
            created_date
        FROM sos_image
        WHERE sos_id = #{sosId}
        ORDER BY sort_order ASC
    </select>
</mapper>